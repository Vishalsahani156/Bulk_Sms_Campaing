{
  "name": "pulse-sms",
  "private": true,
  "scripts": {
    "start": "concurrently -n frontend,backend -c blue,green \"npm run dev --prefix frontend\" \"npm run dev --prefix backend\"",
    "dev": "npm run start",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "setup:local": "bash scripts/setup-local.sh",
    "db:migrate": "npm run db:migrate --prefix backend",
    "build": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
