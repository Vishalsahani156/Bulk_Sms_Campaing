# Razorpay (test keys from https://dashboard.razorpay.com/app/keys)
# Server-only — never expose the secret to the client
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_here

# Public key for Razorpay Checkout (same Key ID as above)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# Optional: Supabase (when moving off mock auth)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
